---
import { BASE_PATH, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href={`${BASE_PATH}/`}>{SITE_TITLE}</a></h2>
		<div class="right-links">
			<HeaderLink href={`${BASE_PATH}/about`}>
				<span class="sr-only">About</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" fill="currentColor"><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.45-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></svg>
			</HeaderLink>
			<a href="https://github.com/profiralex" target="_blank" rel="noopener">
				<span class="sr-only">Alexandr Profir on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<a href="https://www.linkedin.com/in/alexandr-profir-a7735594/" target="_blank" rel="noopener">
				<span class="sr-only">Alexandr Profir on LinkedIn</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"
					></path></svg
				>
			</a>
			<button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle theme" style="padding-bottom: 30px;">
				<svg viewBox="0 0 24 24" width="32" height="32" aria-hidden="true">
					<defs>
						<mask id="theme-toggle-mask">
							<rect x="0" y="0" width="24" height="24" fill="white" />
							<circle class="theme-toggle-mask-circle" cx="24" cy="4" r="6" fill="black" />
						</mask>
					</defs>
					<circle class="theme-toggle-disc" cx="12" cy="12" r="6" fill="currentColor" mask="url(#theme-toggle-mask)" />
					<g class="theme-toggle-rays" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
						<line x1="12" y1="1" x2="12" y2="3" />
						<line x1="12" y1="21" x2="12" y2="23" />
						<line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
						<line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
						<line x1="1" y1="12" x2="3" y2="12" />
						<line x1="21" y1="12" x2="23" y2="12" />
						<line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
						<line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
					</g>
				</svg>
			</button>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--surface-bg);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.right-links {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1em 0.5em;
		background: transparent;
		border: none;
		border-bottom: 4px solid transparent;
		color: inherit;
		cursor: pointer;
		font: inherit;
		line-height: inherit;
	}
	.theme-toggle:hover {
		color: var(--accent);
	}
	.theme-toggle-disc {
		transition: r 0.35s ease;
	}
	.theme-toggle-mask-circle {
		transition: cx 0.45s ease, cy 0.45s ease;
	}
	.theme-toggle-rays {
		transform-origin: 12px 12px;
		transition: opacity 0.3s ease, transform 0.4s ease;
	}
	:root[data-theme='dark'] .theme-toggle-disc {
		r: 8;
	}
	:root[data-theme='dark'] .theme-toggle-mask-circle {
		cx: 17;
		cy: 7;
	}
	:root[data-theme='dark'] .theme-toggle-rays {
		opacity: 0;
		transform: scale(0.5);
	}
	@media (prefers-reduced-motion: reduce) {
		.theme-toggle-disc,
		.theme-toggle-mask-circle,
		.theme-toggle-rays {
			transition: none;
		}
	}
</style>

<script>
	const btn = document.querySelector('[data-theme-toggle]');
	btn?.addEventListener('click', () => {
		const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
		document.documentElement.dataset.theme = next;
		localStorage.setItem('theme', next);
	});
</script>
