---
export interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;

interface TreeItem {
	heading: Heading;
	children: TreeItem[];
}

function buildTree(headings: Heading[]): TreeItem[] {
	const filtered = headings
		.filter((h) => h.depth > 1 && h.text)
		.map((h) => ({
			...h,
			text: (h.text ?? '').replace(/\s*#$/, ''),
		}));
	const root: TreeItem[] = [];
	const stack: { depth: number; children: TreeItem[] }[] = [
		{ depth: 1, children: root },
	];

	for (const heading of filtered) {
		const item: TreeItem = { heading, children: [] };

		while (stack.length > 0 && stack[stack.length - 1].depth >= heading.depth) {
			stack.pop();
		}

		stack[stack.length - 1].children.push(item);
		stack.push({ depth: heading.depth, children: item.children });
	}

	return root;
}

const tree = buildTree(headings);
const showToc = tree.length > 0;

function renderTree(items: TreeItem[]): string {
	if (items.length === 0) return '';
	let html = '<ul>';
	for (const item of items) {
		const escaped = item.heading.text
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;');
		html += `<li><a href="#${item.heading.slug}">${escaped}</a>${renderTree(item.children)}</li>`;
	}
	html += '</ul>';
	return html;
}
---

{
	showToc && (
		<>
			<details class="toc-mobile">
				<summary class="toc-label">On this page</summary>
				<div class="toc-list" set:html={renderTree(tree)} />
			</details>
			<nav class="toc" aria-label="Table of contents">
				<div class="toc-label">On this page</div>
				<div class="toc-list" set:html={renderTree(tree)} />
			</nav>
		</>
	)
}

<script is:inline>
(function() {
	if (window.innerWidth < 1024) return;

	const links = document.querySelectorAll('.toc .toc-list a');
	if (!links.length) return;

	const headings = [];
	for (const link of links) {
		const id = link.getAttribute('href')?.slice(1);
		if (id) {
			const el = document.getElementById(id);
			if (el) headings.push(el);
		}
	}
	if (!headings.length) return;

	function update() {
		const scrollY = window.scrollY + 100;
		let idx = -1;
		for (let i = 0; i < headings.length; i++) {
			if (headings[i].offsetTop <= scrollY) idx = i;
			else break;
		}

		const last = headings[headings.length - 1];
		const contentEnd = last.offsetTop + last.offsetHeight;
		const atBottom = window.scrollY + window.innerHeight >= contentEnd
			&& window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 200;

		links.forEach((link, i) => {
			link.classList.toggle('active', !atBottom && i === idx);
		});
	}

	window.addEventListener('scroll', update, { passive: true });
	window.addEventListener('resize', update, { passive: true });
	update();
})();
</script>

<style>
	.toc-mobile {
		display: block;
		margin: 1.5rem 0;
		padding: 1rem 1.25rem;
		background: rgba(var(--gray-light), 0.35);
		border-left: 3px solid var(--accent);
		border-radius: 0 8px 8px 0;
	}

	.toc {
		display: none;
		margin: 1.5rem 0;
		padding: 1rem 1.25rem;
		background: rgba(var(--gray-light), 0.35);
		border-left: 3px solid var(--accent);
		border-radius: 0 8px 8px 0;
	}

	.toc-label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
	}

	.toc-mobile .toc-label {
		cursor: pointer;
	}

	.toc-mobile .toc-label::marker {
		color: rgb(var(--gray));
	}

	.toc-list {
		margin: 0.5rem 0 0;
	}

	.toc-list ul {
		list-style: none;
		padding: 0 0 0 1rem;
		margin: 0;
	}

	.toc-list > ul {
		padding: 0;
	}

	.toc-list li {
		margin: 0;
		padding: 0;
	}

	.toc-list a {
		display: block;
		padding: 0.2rem 0;
		font-size: 0.875rem;
		line-height: 1.4;
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.15s ease;
		border: none;
	}

	.toc-list a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.toc-list a.active {
		color: var(--accent);
		font-weight: 600;
	}

	@media (min-width: 1024px) {
		.toc-mobile {
			display: none;
		}

		.toc {
			display: block;
		}

		.toc-label {
			cursor: default;
		}
	}
</style>
