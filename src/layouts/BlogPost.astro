---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import avatar from '../assets/avatar.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingTime: number };

const { title, description, pubDate, updatedDate, heroImage, tags, readingTime } = Astro.props;
const ogImage = new URL(`/og/${Astro.params.slug}.png`, Astro.site).href;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={ogImage} />
		<style>
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				padding: 1em 0;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				line-height: 1.2;
			}
			.byline {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.5rem;
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin: 0;
			}
			.byline-avatar {
				width: 24px;
				height: 24px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.byline-name {
				font-weight: 600;
				color: rgb(var(--gray-dark));
			}
			.byline-sep {
				color: rgb(var(--gray));
			}
			.last-updated-on {
				margin: 0.25rem 0 0;
				color: rgb(var(--gray));
				font-style: italic;
				font-size: 0.9em;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				margin: 0.75rem 0 0;
				padding: 0;
			}
			.tags li {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				padding: 0.25em 0.75em;
				border-radius: 999px;
				font-size: 0.85em;
				font-weight: 600;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="byline">
							<Image src={avatar} alt="Alexandr Profir" width={48} height={48} class="byline-avatar" />
							<span class="byline-name">Alexandr Profir</span>
							<span class="byline-sep">·</span>
							<FormattedDate date={pubDate} />
							<span class="byline-sep">·</span>
							<span>{readingTime} min</span>
						</div>
						{updatedDate && (
							<p class="last-updated-on">
								Last updated on <FormattedDate date={updatedDate} />
							</p>
						)}
						{tags && tags.length > 0 && (
							<ul class="tags">
								{tags.map((tag) => <li>{tag}</li>)}
							</ul>
						)}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	<script is:inline type="module">
		import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
		mermaid.initialize({ startOnLoad: false });
		document.querySelectorAll('pre[data-language="mermaid"]').forEach((el) => {
			const container = document.createElement('div');
			container.className = 'mermaid';
			container.textContent = el.querySelector('code').innerText;
			el.replaceWith(container);
		});
		await mermaid.run();
	</script>
	</body>
</html>
