---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import avatar from '../assets/avatar.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import type { Heading } from '../components/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime: number;
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, heroImage, tags, readingTime, prevPost, nextPost, headings } = Astro.props;
const ogImage = new URL(`/og/${Astro.params.slug}.png`, Astro.site).href;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={ogImage} />
		<style>
			main {
				max-width: 1024px;
				width: 100%;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.hero-svg {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				padding: 1em 0;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				line-height: 1.2;
			}
			.byline {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 0.5rem;
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin: 0;
			}
			.byline-avatar {
				width: 24px;
				height: 24px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.byline-name {
				font-weight: 600;
				color: rgb(var(--gray-dark));
			}
			.byline-sep {
				color: rgb(var(--gray));
			}
			.last-updated-on {
				margin: 0.25rem 0 0;
				color: rgb(var(--gray));
				font-style: italic;
				font-size: 0.9em;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				margin: 0.75rem 0 0;
				padding: 0;
			}
			.tags li {
				padding: 0;
			}
			.tags a {
				display: inline-block;
				text-decoration: none;
				padding: 0.156em 0.469em;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				border-radius: 999px;
				font-size: 0.531em;
				font-weight: 600;
				transition: background 0.15s ease, color 0.15s ease;
			}
			.tags a:hover {
				background: var(--accent);
				color: #fff;
				text-decoration: none;
			}
			.content-area {
				padding: 1em 0;
			}
			.post-footer {
				margin-top: 3rem;
				padding-bottom: 1rem;
			}
			.author-block {
				display: flex;
				gap: 1.25rem;
				align-items: flex-start;
				padding: 1.5rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				margin-bottom: 1.5rem;
			}
			.author-avatar {
				width: 64px;
				height: 64px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.author-info {
				flex: 1;
				min-width: 0;
			}
			.author-name {
				font-weight: 700;
				font-size: 1rem;
				color: rgb(var(--black));
				margin: 0 0 0.25rem;
			}
			.author-bio {
				margin: 0 0 0.75rem;
				color: rgb(var(--gray-dark));
				font-size: 0.875rem;
				line-height: 1.5;
			}
			.author-social {
				display: flex;
				gap: 0.75rem;
				align-items: center;
			}
			.author-social a {
				color: rgb(var(--gray));
				display: flex;
				align-items: center;
				text-decoration: none;
				transition: color 0.15s ease;
			}
			.author-social a:hover {
				color: var(--accent);
				text-decoration: none;
			}
			.post-nav {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
			}
			.post-nav-next {
				text-align: right;
			}
			.post-nav a {
				display: block;
				text-decoration: none;
				color: inherit;
				padding: 0.75rem 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				transition: border-color 0.15s ease;
				height: 100%;
				box-sizing: border-box;
			}
			.post-nav a:hover {
				border-color: var(--accent);
				text-decoration: none;
			}
			.nav-direction {
				display: block;
				font-size: 0.8rem;
				font-weight: 600;
				color: rgb(var(--gray));
				margin-bottom: 0.25rem;
			}
			.nav-title {
				display: block;
				font-size: 0.95rem;
				font-weight: 600;
				color: rgb(var(--black));
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			@media (min-width: 1024px) {
				.prose {
					max-width: 720px;
					margin: 0 auto;
				}
			}
			@media (max-width: 480px) {
				.post-nav {
					grid-template-columns: 1fr;
				}
				.post-nav-next {
					text-align: left;
				}
				.author-block {
					flex-direction: column;
					align-items: center;
					text-align: center;
				}
				.author-social {
					justify-content: center;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage
						? <Image width={1020} height={510} src={heroImage} alt="" />
						: <img src={`/heroes/${Astro.params.slug}.svg`} class="hero-svg" alt="" width="800" height="300" />
					}
				</div>
				<div class="content-area">
					<div class="prose">
						<div class="title">
							<h1>{title}</h1>
							<div class="byline">
								<Image src={avatar} alt="Alexandr Profir" width={48} height={48} class="byline-avatar" />
								<span class="byline-name">Alexandr Profir</span>
								<span class="byline-sep">·</span>
								<FormattedDate date={pubDate} />
								<span class="byline-sep">·</span>
								<span>{readingTime} min</span>
							</div>
							{updatedDate && (
								<p class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</p>
							)}
							{tags && tags.length > 0 && (
								<ul class="tags">
									{tags.map((tag) => (
									<li><a href={`/tags/${tag}/`}>{tag}</a></li>
								))}
								</ul>
							)}
							<hr />
						</div>
													<TableOfContents headings={headings ?? []} />
							<slot />
					</div>
					

				</div>
				<div class="post-footer">
					<div class="author-block">
						<Image src={avatar} alt="Alexandr Profir" width={128} height={128} class="author-avatar" />
						<div class="author-info">
							<div class="author-name">Alexandr Profir</div>
							<div class="author-bio">Senior Engineer building distributed systems and cloud infrastructure in Go.</div>
							<div class="author-social">
								<a href="https://github.com/profiralex" target="_blank" rel="noopener">
									<span class="sr-only">GitHub</span>
									<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
								</a>
								<a href="https://www.linkedin.com/in/alexandr-profir-a7735594/" target="_blank" rel="noopener">
									<span class="sr-only">LinkedIn</span>
									<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"><path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>
								</a>
								<a href="https://x.com/AlexandruProfir" target="_blank" rel="noopener">
									<span class="sr-only">X (Twitter)</span>
									<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
								</a>
							</div>
						</div>
					</div>

					{(prevPost || nextPost) && (
						<nav class="post-nav">
							<div class="post-nav-prev">
								{prevPost && (
									<a href={`/blog/${prevPost.id}/`}>
										<span class="nav-direction">← Older post</span>
										<span class="nav-title">{prevPost.data.title}</span>
									</a>
								)}
							</div>
							<div class="post-nav-next">
								{nextPost && (
									<a href={`/blog/${nextPost.id}/`}>
										<span class="nav-direction">Newer post →</span>
										<span class="nav-title">{nextPost.data.title}</span>
									</a>
								)}
							</div>
						</nav>
					)}
				</div>
			</article>
		</main>
		<Footer />
	<script is:inline type="module">
		import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
		mermaid.initialize({ startOnLoad: false });
		document.querySelectorAll('pre[data-language="mermaid"]').forEach((el) => {
			const container = document.createElement('div');
			container.className = 'mermaid';
			container.textContent = el.querySelector('code').innerText;
			el.replaceWith(container);
		});
		await mermaid.run();
	</script>
	</body>
</html>
