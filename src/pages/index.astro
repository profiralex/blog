---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { BASE_PATH, SITE_DESCRIPTION, SITE_TITLE, STYLE_VARIABLES } from '../consts';

const pinned = ['hello-world'];
const allPosts = await getCollection('blog');
const posts = [
	...allPosts.filter((p) => pinned.includes(p.id)),
	...allPosts
		.filter((p) => !pinned.includes(p.id))
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			li {
				padding: 1.75rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			li:first-child {
				padding-top: 0.5rem;
			}
			li:last-child {
				border-bottom: none;
			}
			a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.pinned {
				display: inline-block;
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin-bottom: 0.5rem;
			}
			.title {
				margin: 0 0 0.35rem;
				font-size: 1.5rem;
				color: rgb(var(--black));
				line-height: 1.3;
				transition: color 0.15s ease;
			}
			a:hover .title {
				color: var(--accent);
			}
			.date {
				margin: 0 0 0.5rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.description {
				margin: 0;
				color: rgb(var(--gray-dark));
				line-height: 1.55;
			}
		</style>
	</head>
	<body style={STYLE_VARIABLES}>
		<Header />
		<main>
			<ul>
				{
					posts.map((post) => {
						const isPinned = pinned.includes(post.id);
						return (
							<li>
								<a href={`${BASE_PATH}/blog/${post.id}/`}>
									{isPinned && <span class="pinned">Pinned</span>}
									<h3 class="title">{post.data.title}</h3>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									{post.data.description && (
										<p class="description">{post.data.description}</p>
									)}
								</a>
							</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
