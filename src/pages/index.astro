---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import avatar from '../assets/avatar.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { BASE_PATH, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const featuredId = 'hello-world';

function readingTime(body: string | undefined): number {
	const words = (body ?? '').split(/\s+/).filter(Boolean).length;
	return Math.max(1, Math.round(words / 220));
}

const allPosts = await getCollection('blog');
const featured = allPosts.find((p) => p.id === featuredId) ?? null;
const otherPosts = allPosts
	.filter((p) => p.id !== featuredId)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: flex;
				align-items: center;
				gap: 1.25rem;
				padding: 1.5rem 0 2rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2rem;
			}
			.hero-avatar {
				width: 72px;
				height: 72px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.hero-name {
				margin: 0 0 0.25rem;
				font-size: 1.5rem;
				font-weight: 700;
				color: rgb(var(--black));
				line-height: 1.2;
			}
			.hero-tagline {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
				line-height: 1.5;
			}
			.featured-card {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				overflow: hidden;
				margin-bottom: 2.5rem;
				transition: border-color 0.15s ease, box-shadow 0.15s ease;
			}
			.featured-card:hover {
				border-color: var(--accent);
				box-shadow: 0 2px 12px rgba(var(--gray), 15%);
			}
			.card-banner {
				width: 100%;
				height: 160px;
				display: block;
				background-size: cover;
				background-position: center;
			}
			.card-body {
				padding: 1.25rem 1.5rem 1rem;
			}
			.featured-card .tags {
				padding: 0 1.5rem 1.25rem;
			}
			.featured-label {
				display: inline-block;
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent);
				margin-bottom: 0.5rem;
			}
			.featured-title {
				margin: 0 0 0.5rem;
				font-size: 1.6rem;
				line-height: 1.25;
				color: rgb(var(--black));
				transition: color 0.15s ease;
			}
			.featured-card a:hover .featured-title {
				color: var(--accent);
			}
			.featured-meta {
				margin: 0 0 0.75rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.featured-desc {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				line-height: 1.6;
			}
			.featured-card > a {
				display: block;
				text-decoration: none;
				color: inherit;
				padding: 0;
			}
			.section-heading {
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0 0 0.25rem;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			li {
				padding: 1.75rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				display: flex;
				gap: 1rem;
				align-items: flex-start;
			}
			li:last-child {
				border-bottom: none;
			}
			.post-thumb {
				width: 80px;
				height: 80px;
				border-radius: 8px;
				flex-shrink: 0;
				margin-top: 0.15rem;
				background-size: cover;
				background-position: center;
			}
			.post-content {
				flex: 1;
				min-width: 0;
			}
			a {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.title {
				margin: 0 0 0.35rem;
				font-size: 1.5rem;
				color: rgb(var(--black));
				line-height: 1.3;
				transition: color 0.15s ease;
			}
			a:hover .title {
				color: var(--accent);
			}
			.date {
				margin: 0 0 0.5rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.description {
				margin: 0;
				color: rgb(var(--gray-dark));
				line-height: 1.55;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				margin: 0.75rem 0 0;
				padding: 0;
			}
			.tags li {
				padding: 0;
				border: none;
				display: block;
			}
			.tags a {
				display: inline-block;
				text-decoration: none;
				padding: 0.156em 0.469em;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				border-radius: 999px;
				font-size: 0.531em;
				font-weight: 600;
				transition: background 0.15s ease, color 0.15s ease;
			}
			.tags a:hover {
				background: var(--accent);
				color: #fff;
				text-decoration: none;
			}
			@media (max-width: 480px) {
				.hero {
					flex-direction: column;
					text-align: center;
					padding: 1.25rem 0 1.75rem;
				}
				.post-thumb {
					width: 56px;
					height: 56px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<Image src={avatar} alt="Alexandr Profir" width={144} height={144} class="hero-avatar" />
				<div>
					<p class="hero-name">Alexandr Profir</p>
					<p class="hero-tagline">Senior Engineer building distributed systems and cloud infrastructure in Go.</p>
				</div>
			</div>

			{featured && (
				<div class="featured-card">
					<a href={`${BASE_PATH}/blog/${featured.id}/`}>
						<div class="card-banner" style={`background-image: url(/heroes/${featured.id}.svg)`} />
						<div class="card-body">
							<span class="featured-label">Featured</span>
							<h2 class="featured-title">{featured.data.title}</h2>
							<p class="featured-meta">
								<FormattedDate date={featured.data.pubDate} /> · {readingTime(featured.body)} min
							</p>
							{featured.data.description && (
								<p class="featured-desc">{featured.data.description}</p>
							)}
						</div>
					</a>
					{featured.data.tags && featured.data.tags.length > 0 && (
						<ul class="tags">
							{featured.data.tags.map((tag) => (
								<li><a href={`${BASE_PATH}/tags/${tag}/`}>{tag}</a></li>
							))}
						</ul>
					)}
				</div>
			)}

			{otherPosts.length > 0 && <p class="section-heading">Latest posts</p>}
			{otherPosts.length > 0 && (
				<ul>
					{otherPosts.map((post) => {
						const rt = readingTime(post.body);
						const tags = post.data.tags;
						return (
							<li>
								<div class="post-thumb" style={`background-image: url(/heroes/${post.id}.svg)`} />
								<div class="post-content">
									<a href={`${BASE_PATH}/blog/${post.id}/`}>
										<h3 class="title">{post.data.title}</h3>
										<p class="date">
											<FormattedDate date={post.data.pubDate} /> · {rt} min
										</p>
										{post.data.description && (
											<p class="description">{post.data.description}</p>
										)}
									</a>
									{tags && tags.length > 0 && (
										<ul class="tags">
											{tags.map((tag) => (
												<li><a href={`${BASE_PATH}/tags/${tag}/`}>{tag}</a></li>
											))}
										</ul>
									)}
								</div>
							</li>
						);
					})}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>
