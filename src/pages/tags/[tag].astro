---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { BASE_PATH, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
	return allTags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: posts
				.filter((p) => p.data.tags?.includes(tag))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

interface Props {
	tag: string;
	posts: CollectionEntry<'blog'>[];
}

const { tag, posts } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Posts tagged "${tag}" · ${SITE_TITLE}`}
			description={`All posts tagged with "${tag}".`}
		/>
		<style>
			.tag-header {
				margin-bottom: 2rem;
			}
			.tag-label {
				display: block;
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin-bottom: 0.25rem;
			}
			.tag-name {
				margin: 0;
				font-size: 2rem;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			li {
				padding: 1.75rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			li:first-child {
				padding-top: 0.5rem;
			}
			li:last-child {
				border-bottom: none;
			}
			.post-link {
				display: block;
				text-decoration: none;
				color: inherit;
			}
			.title {
				margin: 0 0 0.35rem;
				font-size: 1.5rem;
				color: rgb(var(--black));
				line-height: 1.3;
				transition: color 0.15s ease;
			}
			.post-link:hover .title {
				color: var(--accent);
			}
			.date {
				margin: 0 0 0.5rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.description {
				margin: 0;
				color: rgb(var(--gray-dark));
				line-height: 1.55;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				margin: 0.75rem 0 0;
				padding: 0;
			}
			.tags li {
				padding: 0;
				border: none;
			}
			.tags a {
				display: inline-block;
				text-decoration: none;
				padding: 0.156em 0.469em;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				border-radius: 999px;
				font-size: 0.75rem;
				font-weight: 600;
				transition: background 0.15s ease, color 0.15s ease;
			}
			.tags a:hover {
				background: var(--accent);
				color: #fff;
				text-decoration: none;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="tag-header">
				<span class="tag-label">Tag</span>
				<h2 class="tag-name">{tag}</h2>
			</div>
			<ul>
				{
					posts.map((post) => {
						const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
						const readingTime = Math.max(1, Math.round(words / 220));
						const tags = post.data.tags;
						return (
							<li>
								<a class="post-link" href={`${BASE_PATH}/blog/${post.id}/`}>
									<h3 class="title">{post.data.title}</h3>
									<p class="date">
										<FormattedDate date={post.data.pubDate} /> · {readingTime} min
									</p>
									{post.data.description && (
										<p class="description">{post.data.description}</p>
									)}
								</a>
								{tags && tags.length > 0 && (
									<ul class="tags">
										{tags.map((t) => (
											<li>
												<a href={`${BASE_PATH}/tags/${t}/`}>{t}</a>
											</li>
										))}
									</ul>
								)}
							</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
