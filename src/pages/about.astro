---
import { Image } from 'astro:assets';
import avatar from '../assets/avatar.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — Alexandr Profir" description="Senior Engineer at CrowdStrike. Go, cloud, backend." />
		<style>
			.profile {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				padding-top: 1rem;
			}
			.header {
				display: flex;
				align-items: center;
				gap: 1.25rem;
			}
			.avatar {
				width: 96px;
				height: 96px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
				box-shadow: var(--box-shadow);
			}
			.name {
				margin: 0;
				font-size: 2.441em;
				line-height: 1.1;
			}
			.role {
				margin: 0.25rem 0 0;
				font-size: 1.1em;
				color: rgb(var(--gray));
			}
			.bio {
				font-size: 1em;
				line-height: 1.7;
				color: rgb(var(--gray-dark));
				margin: 0;
			}
			.section-label {
				font-size: 0.75em;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin: 0 0 0.75rem;
			}
			.skills {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.skills li {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				padding: 0.25em 0.75em;
				border-radius: 999px;
				font-size: 0.85em;
				font-weight: 600;
			}
			.links {
				display: flex;
				flex-direction: column;
				gap: 0.6rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.links a {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
			}
			.links a:hover {
				text-decoration: underline;
			}
			hr {
				border: none;
				border-top: 1px solid rgb(var(--gray-light));
				margin: 0;
			}
		</style>
	</head>
	<body style={`--bg-image: url('${import.meta.env.BASE_URL}/network-bg.svg')`}>
		<Header />
		<main>
			<div class="profile">
				<div class="header">
					<Image src={avatar} alt="Alexandr Profir" width={96} height={96} class="avatar" />
					<div>
						<h1 class="name">Alexandr Profir</h1>
						<p class="role">Senior Engineer · CrowdStrike</p>
					</div>
				</div>

				<hr />

				<p class="bio">
					Backend and cloud engineer with a focus on Go. I build reliable, scalable systems and
					enjoy working close to the infrastructure layer — distributed services, cloud-native
					architecture, and everything in between.
				</p>

				<div>
					<p class="section-label">Skills</p>
					<ul class="skills">
						<li>Go</li>
						<li>Cloud Engineering</li>
						<li>Backend Development</li>
						<li>Distributed Systems</li>
						<li>AWS</li>
						<li>Kubernetes</li>
					</ul>
				</div>

				<hr />

				<div>
					<p class="section-label">Links</p>
					<ul class="links">
						<li>
							<a href="https://github.com/profiralex" target="_blank" rel="noopener">
								<svg width="18" height="18" viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
								github.com/profiralex
							</a>
						</li>
						<li>
							<a href="https://www.linkedin.com/in/alexandr-profir-a7735594/" target="_blank" rel="noopener">
								<svg width="18" height="18" viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>
								linkedin.com/in/alexandr-profir
							</a>
						</li>
					</ul>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
